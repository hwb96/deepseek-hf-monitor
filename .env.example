# Hugging Face monitor target
HF_AUTHOR=deepseek-ai
HF_LIMIT=100
CONTAINS=

# Runtime behavior
CHECK_INTERVAL_SECONDS=1800
BOOTSTRAP_IF_MISSING=true
STATE_FILE=state/models.json
HEARTBEAT_FILE=state/heartbeat.json

# Optional: fallback env file with lowest priority.
# Use this to reuse existing EMAIL_* variables from another project.
# Example: EXTERNAL_ENV_FILE=/run/external/external.env
EXTERNAL_ENV_FILE=

# Email notification
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVERS=
EMAIL_SENDER_NAME=deepseek-hf-monitor

# Healthcheck override (optional)
# Default is CHECK_INTERVAL_SECONDS*2+60
HEALTHCHECK_MAX_AGE_SECONDS=
